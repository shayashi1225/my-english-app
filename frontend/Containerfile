FROM registry.access.redhat.com/ubi9/nodejs-20:latest AS builder

USER root
WORKDIR /app
COPY frontend/package*.json ./
RUN npm ci
COPY frontend/ .
RUN npm run build

FROM registry.access.redhat.com/ubi8/nginx-120:latest

# UBI nginx uses /opt/app-root/src as document root
# and /opt/app-root/etc/nginx.default.d/ for server-block includes
COPY --from=builder /app/dist /opt/app-root/src
COPY nginx/nginx.conf /opt/app-root/etc/nginx.default.d/app.conf

EXPOSE 8080

CMD ["nginx", "-g", "daemon off;"]
